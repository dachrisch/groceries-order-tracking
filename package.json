{
  "name": "groceries-order-tracking",
  "version": "1.1.0",
  "description": "Track grocery orders and price trends from Knuspr",
  "main": "src/api/server.ts",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "tsx watch src/api/server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild src/api/server.ts --bundle --platform=node --outfile=dist-server/server.js --format=esm --packages=external",
    "start:prod": "node dist-server/server.js",
    "serve": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "release": "standard-version && git push --follow-tags origin HEAD",
    "release:patch": "standard-version --release-as patch && git push --follow-tags origin HEAD",
    "release:minor": "standard-version --release-as minor && git push --follow-tags origin HEAD",
    "release:major": "standard-version --release-as major && git push --follow-tags origin HEAD",
    "db:dump": "tsx scripts/db-dump.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dachrisch/groceries-order-tracking.git"
  },
  "license": "ISC",
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-solid": "^0.577.0",
    "mongodb": "^7.1.0",
    "mongoose": "^9.3.1",
    "solid-chartjs": "^1.3.11",
    "solid-js": "^1.9.11",
    "standard-version": "^9.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.0"
  }
}
