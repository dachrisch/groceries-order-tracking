{
  "name": "groceries-order-tracking",
  "version": "1.0.0",
  "description": "Track grocery orders and price trends from Knuspr",
  "main": "src/api/server.ts",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "tsx watch src/api/server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild src/api/server.ts --bundle --platform=node --outfile=dist-server/server.js --format=esm --packages=external",
    "start:prod": "node dist-server/server.js",
    "serve": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dachrisch/groceries-order-tracking.git"
  },
  "license": "ISC",
  "dependencies": {
    "@solidjs/router": "^0.15.4",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-solid": "^0.477.0",
    "mongodb": "^6.14.2",
    "mongoose": "^8.12.1",
    "solid-chartjs": "^1.3.11",
    "solid-js": "^1.9.11",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mongoose": "^5.11.96",
    "concurrently": "^9.1.2",
    "daisyui": "^5.0.0",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.0.12",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.11"
  }
}
